# ============================================
# E-Commerce Application — Environment Config
# ============================================
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
#
# NEVER commit .env to version control!

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Authentication ---
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_STRONG_SECRET

# --- Database ---
DATABASE_URL=./backend/database.db

# --- CORS (Production only) ---
ALLOWED_ORIGIN=https://your-domain.com

# --- Internal Service URLs (Microservice-ready) ---
USER_SERVICE_URL=http://localhost:3000/api/verify
CATALOG_SERVICE_URL=http://localhost:3000/api/products

# --- Business Rules ---
MAX_CART_ITEMS=100
